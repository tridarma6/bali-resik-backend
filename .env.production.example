# Server Configuration
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30
SERVER_WRITE_TIMEOUT=30

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=bali_resik
DB_PASSWORD=change-this-to-strong-password
DB_NAME=bali_resik
DB_SSLMODE=require
DB_MAX_OPEN=50
DB_MAX_IDLE=20

# JWT Configuration
JWT_SECRET=generate-a-strong-256-bit-secret-key
JWT_ACCESS_TTL=15
JWT_REFRESH_TTL=10080

# Logging
LOG_LEVEL=warn
LOG_FORMAT=json

# File Uploads
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE=10

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1
